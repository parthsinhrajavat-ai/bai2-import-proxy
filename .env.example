# Render bai2-parser service (public, unmodifiable moov/bai2 image).
RENDER_PARSER_URL=https://bai2-parser.onrender.com/format

# Salesforce Connected App - Client Credentials Flow.
# Setup -> App Manager -> New Connected App -> Enable OAuth Settings ->
# check "Enable Client Credentials Flow" -> set a Run As user -> Save,
# then open the app -> Manage Consumer Details for the Consumer Key/Secret.
SF_LOGIN_URL=https://banksummarydevonly-dev-ed.develop.my.salesforce.com/
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_API_VERSION=v67.0

# Comma-separated list of origins allowed to call this proxy (your org's Visualforce/Lightning
# domain(s), e.g. https://yourdomain.lightning.force.com,https://yourdomain--c.vf.force.com).
# "*" is fine for local testing only - lock this down before going live.
ALLOWED_ORIGIN=*

PORT=3000
